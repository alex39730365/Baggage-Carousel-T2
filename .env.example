# 로컬 `npm run dev` 시 Vite 프록시가 공공데이터 API에 붙일 때 사용합니다.
# 비워 두면 개발 모드에서만 코드에 포함된 데모 키로 대체됩니다. 운영·본인 키는 반드시 설정하세요.
VITE_DATA_GO_KR_SERVICE_KEY=

# 프론트 빌드: API가 다른 도메인일 때 절대 URL (예: https://gw.airline.com/api/baggage-arrivals).
# 비우면 브라우저는 현재 사이트 기준 `/api/baggage-arrivals` 호출.
# VITE_BAGGAGE_ARRIVALS_URL=

# 로컬 개발 프록시 대상(기본: 공공데이터 호스트). 사내 스테이징 게이트웨이로 바꿀 수 있음.
# VITE_DEV_BAGGAGE_PROXY_TARGET=https://apis.data.go.kr
# VITE_DEV_BAGGAGE_PROXY_PATH=/B551177/statusOfBaggageClaimDesk/getFltArrivalsBaggageClaimDesk

# Vercel 서버리스(api/baggage-arrivals). Production 배포에서는 필수입니다.
# Preview/로컬에서 비우면 데모 키로 대체됩니다.
DATA_GO_KR_SERVICE_KEY=

# --- 서버(api/baggage-arrivals) 전용: 사내·항공사 연동 시 ---

# 페이지네이션 업스트림 URL(쿼리: serviceKey,type,numOfRows,pageNo,searchDay). 미설정 시 인천 공공데이터 기본 URL.
# BAGGAGE_DATA_UPSTREAM_URL=

# 단일 GET으로 합쳐진 JSON을 주는 사내 API — 설정 시 공공데이터 페이지네이션 대신 이 URL만 호출.
# 응답: 공공데이터와 동일 `response.body.items` 형식, 또는 `item[]` 배열.
# BAGGAGE_UPSTREAM_SNAPSHOT_URL=
# BAGGAGE_UPSTREAM_AUTHORIZATION=Bearer ...

# 게이트웨이가 serviceKey 쿼리를 쓰지 않을 때 false
# BAGGAGE_PAGINATED_APPEND_SERVICE_KEY=true

# 정적 프론트가 다른 도메인일 때 CORS (예: https://ops.airline.com)
# BAGGAGE_API_CORS_ORIGIN=

# 선택: Vercel Storage → KV(또는 연동된 Upstash Redis). 설정 시 인스턴스 간 스냅샷 공유로
# apis.data.go.kr 호출 횟수가 크게 줄어듭니다. 미설정 시 기존처럼 인스턴스 메모리 캐시만 사용합니다.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
