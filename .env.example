# 로컬 `npm run dev` 시 Vite 프록시가 공공데이터 API에 붙일 때 사용합니다.
# 비워 두면 개발 모드에서만 코드에 포함된 데모 키로 대체됩니다. 운영·본인 키는 반드시 설정하세요.
VITE_DATA_GO_KR_SERVICE_KEY=

# Vercel 서버리스(api/baggage-arrivals). Production 배포에서는 필수입니다.
# Preview/로컬에서 비우면 데모 키로 대체됩니다.
DATA_GO_KR_SERVICE_KEY=

# 선택: Vercel Storage → KV(또는 연동된 Upstash Redis). 설정 시 인스턴스 간 스냅샷 공유로
# apis.data.go.kr 호출 횟수가 크게 줄어듭니다. 미설정 시 기존처럼 인스턴스 메모리 캐시만 사용합니다.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
